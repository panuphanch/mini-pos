{
  "$schema": "https://raw.githubusercontent.com/nicovank/tauri-docs/refs/heads/main/packages/api/src/core/config.schema.json",
  "productName": "Granny's POS",
  "version": "0.1.0",
  "identifier": "com.grannysaidso.pos",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "title": "Granny's POS",
    "windows": [
      {
        "title": "Granny's POS",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
